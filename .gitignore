# Python Virtual Environment and caches
backend/venv/
backend/__pycache__/
backend/app/__pycache__/
backend/app/**/__pycache__/

# Databases and keys (important: exclude credentials and backups)
**/*.db
**/*.db-shm
**/*.db-wal
**/data/backups/
**/*.key

# Frontend dependencies and builds
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.production
.env
backend/.env

# System and IDE configuration
.idea/
.vscode/
.DS_Store
Thumbs.db
*.log
